OPENROUTER_API_KEY=sk-or-v1-tu-api-key-aqui

# UF de referencia en pesos por 1 UF (opcional).
# Si están definidos, el pipeline los usa en el prompt y recalcula CLP en el JSON.
UF_REFERENCE_CLP=
# Fecha de referencia de ese valor, formato YYYY-MM-DD
UF_REFERENCE_DATE=

# Si es true, y no hay UF manual ni UF_REFERENCE_CLP, se consulta mindicador.cl al ejecutar.
FETCH_UF_ONLINE=false
